## Global Variabel
#@BaseUrl = https://pam-2026-p5-laundry-be.delcom.org:8080
@BaseUrl = http://127.0.0.1:8000

### ---------------------------------------
## Auth
### ---------------------------------------

### Melakukan pendaftaran
# @name PostRegister
POST {{BaseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Tester",
  "username": "tester",
  "password": "tester123"
}

### Masuk ke layanan
# @name PostLogin
POST {{BaseUrl}}/auth/login
Content-Type: application/json

{
  "username": "tester",
  "password": "tester123"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### Refresh Token
# @name PostRefreshToken
POST {{BaseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "authToken": "{{authToken}}",
  "refreshToken": "{{refreshToken}}"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### Logout
# @name PostLogout
POST {{BaseUrl}}/auth/logout
Content-Type: application/json

{
  "authToken": "{{authToken}}"
}

### ---------------------------------------
## Users
### ---------------------------------------

### Mengambil informasi akun
# @name GetUserMe
GET {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
    client.global.set("userId", response.body.data.user.id);
%}

### Mengubah informasi akun
# @name PutUserMe
PUT {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Tester Update",
  "username": "tester"
}

### Mengubah kata sandi akun
# @name PutUserMePassword
PUT {{BaseUrl}}/users/me/password
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "password": "tester123",
  "newPassword": "tester123"
}

### Mengubah photo profile
# @name PutUserMePhoto
PUT {{BaseUrl}}/users/me/photo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil foto user berdasarkan ID
@userId = 00000000-0000-0000-0000-000000000000

# @name GetUserPhoto
GET {{BaseUrl}}/images/users/{{userId}}
Authorization: Bearer {{authToken}}

### ---------------------------------------
## Laundry Services (Jenis Layanan)
### ---------------------------------------

### Mengambil semua layanan laundry
# @name GetLaundryServices
GET {{BaseUrl}}/laundry-services?search=&isActive=true
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menambahkan layanan laundry
# @name PostLaundryService
POST {{BaseUrl}}/laundry-services
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Cuci Kiloan",
  "description": "Layanan cuci pakaian per kilogram, mencuci dan menyetrika",
  "price": 7000,
  "unit": "kg",
  "estimatedDays": 2,
  "isActive": true
}

> {%
    client.global.set("serviceId", response.body.data.serviceId);
%}

### Mengambil layanan laundry berdasarkan ID
# @name GetLaundryServiceById
GET {{BaseUrl}}/laundry-services/{{serviceId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengubah layanan laundry
# @name PutLaundryService
PUT {{BaseUrl}}/laundry-services/{{serviceId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Cuci Kiloan Express",
  "description": "Layanan cuci kilat, selesai dalam 1 hari",
  "price": 12000,
  "unit": "kg",
  "estimatedDays": 1,
  "isActive": true
}

### Mengubah gambar layanan laundry
# @name PutLaundryServiceImage
PUT {{BaseUrl}}/laundry-services/{{serviceId}}/image
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="service.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil gambar layanan laundry
# @name GetLaundryServiceImage
GET {{BaseUrl}}/images/laundry-services/{{serviceId}}
Authorization: Bearer {{authToken}}

### Menghapus layanan laundry
# @name DeleteLaundryService
DELETE {{BaseUrl}}/laundry-services/{{serviceId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### ---------------------------------------
## Laundry Orders (Pesanan)
### ---------------------------------------

### Mengambil semua pesanan laundry (dengan pagination & filter)
# @name GetLaundryOrders
GET {{BaseUrl}}/laundry-orders?search=&status=&page=1&limit=10
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menambahkan pesanan laundry
# @name PostLaundryOrder
POST {{BaseUrl}}/laundry-orders
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "serviceId": "{{serviceId}}",
  "customerName": "Budi Santoso",
  "customerPhone": "081234567890",
  "quantity": 3.5,
  "totalPrice": 24500,
  "notes": "Pakaian warna putih dipisah",
  "pickupDate": "2026-03-20T08:00:00Z",
  "deliveryDate": "2026-03-22T08:00:00Z"
}

> {%
    client.global.set("orderId", response.body.data.orderId);
%}

### Mengambil pesanan laundry berdasarkan ID
# @name GetLaundryOrderById
GET {{BaseUrl}}/laundry-orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengubah pesanan laundry
# @name PutLaundryOrder
PUT {{BaseUrl}}/laundry-orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "serviceId": "{{serviceId}}",
  "customerName": "Budi Santoso Update",
  "customerPhone": "081234567890",
  "quantity": 4.0,
  "totalPrice": 28000,
  "notes": "Tolong lipat rapi",
  "pickupDate": "2026-03-20T08:00:00Z",
  "deliveryDate": "2026-03-22T08:00:00Z"
}

### Mengubah status pesanan laundry
# @name PutLaundryOrderStatus
PUT {{BaseUrl}}/laundry-orders/{{orderId}}/status
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "status": "processing"
}

### Filter pesanan berdasarkan status
# @name GetLaundryOrdersByStatus
GET {{BaseUrl}}/laundry-orders?status=pending&page=1&limit=10
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Pencarian pesanan berdasarkan nama pelanggan
# @name SearchLaundryOrders
GET {{BaseUrl}}/laundry-orders?search=Budi&page=1&limit=10
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menghapus pesanan laundry
# @name DeleteLaundryOrder
DELETE {{BaseUrl}}/laundry-orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json
